---
// src/pages/admin/login.astro
export const prerender = false;

let errorMensaje = "";

const url = new URL(Astro.request.url);
if (url.searchParams.get("error") === "no_autorizado") {
  errorMensaje = "Tu cuenta de Google no está registrada en la lista blanca de administradores.";
} else if (url.searchParams.get("error") === "error_auth") {
  errorMensaje = "Ocurrió un error al procesar el retorno de autenticación.";
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar Sesión | Acute Control</title>
</head>
<body class="bg-[#0b1120] text-[#f8fafc] font-sans antialiased min-h-screen">
  
  <div class="flex min-h-screen flex-col md:flex-row">
    
    <div class="hidden md:flex md:w-1/2 bg-gradient-to-br from-[#0f172a] via-[#0b1120] to-[#1e1b4b] border-r border-slate-800/60 p-12 flex-col justify-between relative overflow-hidden">
      <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl"></div>
      
      <div class="flex items-center gap-3 relative z-10">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-500/10 border border-blue-500/20 text-cyan-400">
          <svg class="w-6 h-6" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M50 20 L30 75" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <path d="M50 20 L70 75" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <path d="M40 50 A 12 12 0 0 0 60 50" stroke="#f8fafc" stroke-width="4" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
        <span class="text-xl font-bold tracking-tight text-white font-mono">Acute<span class="text-blue-400">.</span></span>
      </div>

    <div class="max-w-md my-auto relative z-10 space-y-6">
        <h1 class="text-4xl font-extrabold tracking-tight text-white leading-tight lg:text-5xl">
          Consola Central.<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-indigo-400">Administración Acute.</span>
        </h1>
        <p class="text-base text-slate-400 leading-relaxed">
          Portal interno para la gestión, auditoría y control operativo de la agencia. Al autenticarte obtendrás acceso directo al CRM para monitorear el estatus de los desarrollos, administrar saldos de clientes y responder cotizaciones del buzón.
        </p>
        
        <div class="pt-4 space-y-3">
          <div class="flex items-center gap-3 text-sm text-slate-300 font-mono">
            <span class="w-2 h-2 rounded-full bg-cyan-400 shadow-lg shadow-cyan-400/50"></span>
            Monitoreo financiero y KPIs de proyectos
          </div>
          <div class="flex items-center gap-3 text-sm text-slate-300 font-mono">
            <span class="w-2 h-2 rounded-full bg-blue-400 shadow-lg shadow-blue-400/50"></span>
            Gestión de clientes y control de abonos
          </div>
          <div class="flex items-center gap-3 text-sm text-slate-300 font-mono">
            <span class="w-2 h-2 rounded-full bg-indigo-400 shadow-lg shadow-indigo-400/50"></span>
            Despacho asíncrono de solicitudes web
          </div>
        </div>
      </div>

      <div class="text-xs text-slate-500 font-mono relative z-10">
        &copy; 2026 Acute Software Agency. Todos los derechos reservados.
      </div>
    </div>

    <div class="w-full md:w-1/2 flex flex-col justify-center px-6 py-12 lg:px-16 xl:px-24 bg-[#090d16]">
      
      <div class="mx-auto w-full max-w-sm">
        
        <div class="md:hidden flex flex-col items-center mb-8 text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-600/10 to-cyan-500/10 border border-blue-500/20 mb-4">
            <svg class="w-10 h-10 text-cyan-400" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 15 L25 80" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
              <path d="M20 72 L25 80 L33 77" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M50 15 L75 80" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
              <path d="M80 72 L75 80 L67 77" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M38 48 A 20 20 0 0 0 62 48" stroke="#f8fafc" stroke-width="3" stroke-linecap="round" fill="none"/>
            </svg>
          </div>
          <h2 class="text-3xl font-extrabold tracking-tight text-white">Acute Control</h2>
        </div>

        <div class="hidden md:block mb-8">
          <h2 class="text-3xl font-bold tracking-tight text-white">Iniciar Sesión</h2>
          <p class="mt-2 text-sm text-slate-400">
            Identifícate para ingresar al panel administrativo.
          </p>
        </div>

        {errorMensaje && (
          <div class="mb-6 bg-rose-500/10 border border-rose-500/20 rounded-xl p-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-rose-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
            <p class="text-xs font-medium text-rose-300 leading-relaxed">{errorMensaje}</p>
          </div>
        )}

        <div class="space-y-4">
          <button
            id="btn-google-login"
            class="w-full flex items-center justify-center gap-3 rounded-xl bg-white hover:bg-slate-100 px-4 py-3.5 text-sm font-bold text-slate-900 transition-all duration-300 active:scale-[0.98] shadow-xl hover:shadow-white/5"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
            </svg>
            Continuar con Google
          </button>
        </div>

        <div class="mt-8 pt-4 border-t border-slate-900 text-center md:text-left">
          <p class="text-[10px] text-slate-500 font-mono tracking-wider uppercase">
            Autenticación Encriptada &bull; OAuth 2.0
          </p>
        </div>

      </div>
      
    </div>
    
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const btn = document.getElementById('btn-google-login');
    if (btn) {
      btn.addEventListener('click', async () => {
        btn.setAttribute('disabled', 'true');
        btn.innerHTML = 'Conectando con Google...';

        try {
          const targetRedirect = `${window.location.origin}/api/auth/callback`;
          
          const { data, error } = await supabase.auth.signInWithOAuth({
            provider: 'google',
            options: {
              redirectTo: targetRedirect,
              flowType: 'pkce'
            }
          });

          if (error) throw error;

          if (data?.url) {
            window.location.href = data.url;
          }
        } catch (err) {
          console.error("Error en OAuth:", err);
          alert("Error al conectar con Google Auth.");
          btn.removeAttribute('disabled');
          btn.innerHTML = 'Continuar con Google';
        }
      });
    }
  </script>

</body>
</html>