---
---
<section id="contact" class="mt-16 rounded-[2rem] border border-slate-800/70 bg-slate-950/80 p-8 shadow-soft sm:p-10">
  <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-start">
    <div>
      <p class="text-sm uppercase tracking-[0.3em] text-brand-400">Contacto & Cotización</p>
      <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">Háblanos de tu idea</h2>
      <p class="mt-5 text-slate-300 leading-8">
        Completa los datos y selecciona el método por el cual prefieres enviarnos la información de tu proyecto. El formulario adaptará el mensaje automáticamente.
      </p>
    </div>
    <form id="quoteForm" class="space-y-6 rounded-3xl bg-slate-900/90 p-6 shadow-xl">
      <label class="block text-sm font-medium text-slate-200">
        Nombre
        <input name="name" type="text" required class="mt-2 w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20" placeholder="Tu nombre" />
      </label>
      <label class="block text-sm font-medium text-slate-200">
        Correo electrónico
        <input name="email" type="email" required class="mt-2 w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20" placeholder="ejemplo@empresa.com" />
      </label>
      <label class="block text-sm font-medium text-slate-200">
        Teléfono (opcional)
        <input name="phone" type="tel" class="mt-2 w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20" placeholder="+52 1 33 1234 5678" />
      </label>
      <label class="block text-sm font-medium text-slate-200">
        Tipo de software
        <select name="softwareType" class="mt-2 w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20">
          <option value="web">Aplicación web</option>
          <option value="mobile">Aplicación móvil</option>
          <option value="saas">Plataforma SaaS</option>
          <option value="api">API / Microservicios</option>
        </select>
      </label>
      <label class="block text-sm font-medium text-slate-200">
        Mensaje breve
        <textarea name="message" rows="4" class="mt-2 w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-slate-100 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20" placeholder="Describe tu proyecto, objetivos y plazos"></textarea>
      </label>

      <div class="grid gap-4 sm:grid-cols-2">
        <button id="submitWhatsApp" type="submit" data-action="whatsapp" class="inline-flex w-full items-center justify-center gap-2.5 rounded-full bg-[#25D366] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#20ba59] focus:outline-none focus:ring-2 focus:ring-[#25D366]/60">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.713-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.413 9.863-9.83.001-2.624-1.023-5.092-2.884-6.954-1.861-1.862-4.333-2.886-6.961-2.887-5.44 0-9.866 4.415-9.869 9.833-.001 1.742.484 3.447 1.407 4.954l-.999 3.648 3.733-.973zm8.006-4.646c-.237-.118-1.402-.691-1.619-.771-.217-.079-.375-.118-.532.118-.158.237-.611.771-.749.928-.139.158-.277.178-.514.059-.237-.118-.999-.368-1.902-1.174-.703-.627-1.177-1.401-1.315-1.638-.139-.237-.015-.365.104-.483.107-.106.237-.277.356-.415.118-.139.158-.237.237-.395.079-.158.04-.297-.02-.415-.06-.118-.532-1.282-.728-1.754-.191-.462-.385-.4-.532-.408-.137-.007-.296-.008-.455-.008-.158 0-.415.06-.633.297-.218.237-.831.811-.831 1.977 0 1.165.85 2.292.969 2.451.119.158 1.674 2.554 4.055 3.577.566.243 1.008.389 1.352.498.57.181 1.088.155 1.498.094.457-.069 1.402-.572 1.6-.1.198-.462.198-.859.139-.929-.058-.069-.217-.109-.454-.228z"/>
          </svg>
          Enviar por WhatsApp
        </button>

        <button id="submitEmail" type="submit" data-action="email" class="inline-flex w-full items-center justify-center gap-2.5 rounded-full bg-[#EA4335] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#d63427] focus:outline-none focus:ring-2 focus:ring-[#EA4335]/60">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          Enviar por Correo
        </button>
      </div>

      <div id="formStatus" class="min-h-[1.5rem] text-sm text-slate-300"></div>
    </form>
  </div>

  <script type="module">
    const OWNER_WHATSAPP_NUMBER = '3131068471';
    const OWNER_EMAIL_ADDRESS = 'acutewebdesign7@gmail.com';

    const form = document.querySelector('#quoteForm');
    const status = document.querySelector('#formStatus');
    const btnWhatsApp = document.getElementById('submitWhatsApp');
    const btnEmail = document.getElementById('submitEmail');

    let currentAction = 'whatsapp';

    console.log('[FormInit] Cargado con soporte FormSubmit integrado.');

    btnWhatsApp?.addEventListener('click', () => { currentAction = 'whatsapp'; });
    btnEmail?.addEventListener('click', () => { currentAction = 'email'; });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      console.log('[FormSubmit] Iniciando proceso de envío...');

      const data = new FormData(form);
      const payload = Object.fromEntries(data.entries());

      if (!payload.message || !payload.message.trim()) {
        status.textContent = 'Por favor escribe tu mensaje.';
        return;
      }

      // Deshabilitar botones de interfaz
      btnWhatsApp?.setAttribute('disabled', 'true');
      btnEmail?.setAttribute('disabled', 'true');

      // 1. LÓGICA DE ENVÍO POR WHATSAPP
      if (currentAction === 'whatsapp') {
        const lines = [
          'Nuevo contacto desde la web (Acute)',
          `Nombre: ${payload.name || '-'}`,
          `Email: ${payload.email || '-'}`,
          `Tipo de software: ${payload.softwareType || '-'}`,
          payload.phone ? `Teléfono cliente: ${payload.phone}` : '',
          'Mensaje:',
          payload.message || '-'
        ].filter(Boolean);

        const ownerPhone = OWNER_WHATSAPP_NUMBER.replace(/\D/g, '');
        const text = encodeURIComponent(lines.join('\n'));
        const waUrl = `https://wa.me/${ownerPhone}?text=${text}`;

        console.log('[FormDispatch] Abriendo WhatsApp en pestaña externa.');
        status.textContent = 'Abriendo WhatsApp...';
        window.open(waUrl, '_blank');

        setTimeout(() => {
          status.textContent = 'Se abrió WhatsApp. Comprueba que el mensaje esté listo para enviar.';
          btnWhatsApp?.removeAttribute('disabled');
          btnEmail?.removeAttribute('disabled');
        }, 1200);

      // 2. LÓGICA DE ENVÍO POR CORREO (UTILIZANDO FORMSUBMIT API VIA FETCH)
      } else if (currentAction === 'email') {
        status.textContent = 'Enviando tu cotización por correo de forma segura...';
        console.log('[FormDispatch] Ejecutando petición HTTP POST hacia FormSubmit...');

        // Preparamos los datos estructurados específicamente para el correo electrónico
        const formData = new FormData();
        formData.append('Nombre del Cliente', payload.name);
        formData.append('Email de Contacto', payload.email);
        formData.append('Teléfono', payload.phone || 'No especificado');
        formData.append('Tipo de Proyecto', payload.softwareType);
        formData.append('Mensaje de Cotización', payload.message);
        
        // Configuraciones extras de FormSubmit para embellecer el flujo
        formData.append('_subject', `Nueva Cotización Web - ${payload.name}`);
        formData.append('_captcha', 'false'); // Desactiva el recaptcha molesto de redirección

        try {
          const response = await fetch(`https://formsubmit.co/ajax/${OWNER_EMAIL_ADDRESS}`, {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });

          console.log('[FormResponse] Estatus del servidor:', response.status);

          if (response.ok) {
            console.log('[FormSuccess] ¡Correo procesado y enviado con éxito!');
            status.innerHTML = '<span class="text-emerald-400 font-medium">¡Cotización enviada con éxito! Nos comunicaremos contigo pronto.</span>';
            form.reset(); // Limpia los inputs del formulario automáticamente
          } else {
            throw new Error('Error en la respuesta del servidor de correos.');
          }
        } catch (error) {
          console.error('[FormError] Falla en la petición fetch de correo:', error);
          status.innerHTML = '<span class="text-rose-400">Hubo un problema al procesar el envío. Inténtalo por WhatsApp.</span>';
        } finally {
          btnWhatsApp?.removeAttribute('disabled');
          btnEmail?.removeAttribute('disabled');
          console.log('[FormUI] Botones restaurados.');
        }
      }
    });
  </script>
</section>