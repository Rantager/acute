---
// Footer.astro - Pie de página profesional con 4 columnas, redes sociales y copyright

interface Props {
  companyName?: string;
  companyDescription?: string;
  email?: string;
  phone?: string;
  location?: string;
}

const {
  companyName = 'Acute',
  companyDescription = 'Transformamos ideas en soluciones de software escalables y de alta calidad.',
  email = 'acutewebdesign7@gmail.com',
  phone = '+52 (313) 106 8671', // Actualizado con tu número correcto y lada de México (+52)
  location = 'Colima, México'
} = Astro.props;

const currentYear = new Date().getFullYear();

// 1. Limpiamos el número de cualquier caracter que no sea dígito
const cleanedPhone = phone.replace(/[^0-9]/g, '');

// 2. Forzamos que use el formato correcto de WhatsApp para México (prefijo 52 + los 10 dígitos)
// Si ya empieza con 52 y tiene 12 dígitos, lo dejamos así; si no, le agregamos el 52 al número de 10 dígitos.
const whatsappNumber = cleanedPhone.startsWith('52') && cleanedPhone.length === 12 
  ? cleanedPhone 
  : `52${cleanedPhone.slice(-10)}`;
---

<footer class="bg-slate-900 border-t border-slate-800/50 mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Main Footer Content (4 Columns) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      
      <!-- Column 1: Identidad de la Empresa -->
      <div class="space-y-4">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg flex items-center justify-center font-bold text-white text-sm">
            A
          </div>
          <span class="text-lg font-bold text-slate-100">{companyName}</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          {companyDescription}
        </p>
        <!-- TODO: Reemplazar con el logo definitivo de la empresa -->
      </div>

      <!-- Column 2: Enlaces Rápidos -->
      <div>
        <h3 class="text-slate-100 font-bold text-sm uppercase tracking-wider mb-4">
          Enlaces Rápidos
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/" class="text-slate-400 hover:text-blue-400 transition-colors duration-300 text-sm font-medium">
              Inicio
            </a>
          </li>
          <li>
            <a href="/servicios" class="text-slate-400 hover:text-blue-400 transition-colors duration-300 text-sm font-medium">
              Servicios
            </a>
          </li>
          <li>
            <a href="/proyectos" class="text-slate-400 hover:text-blue-400 transition-colors duration-300 text-sm font-medium">
              Proyectos
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Contacto & Soporte -->
      <div>
        <h3 class="text-slate-100 font-bold text-sm uppercase tracking-wider mb-4">
          Contacto & Soporte
        </h3>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${email}`} class="flex items-center gap-2 text-slate-400 hover:text-blue-400 transition-colors duration-300 text-sm font-medium group">
              <svg class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
              </svg>
              <span class="break-all">{email}</span>
            </a>
          </li>
          <li>
            <a href={`tel:${phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-slate-400 hover:text-blue-400 transition-colors duration-300 text-sm font-medium group">
              <svg class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773c.058.3.102.605.102.924v1.902c0 .141-.009.283-.025.423l1.487.734a1 1 0 01.538 1.062l-.74 4.435a1 1 0 01-.986.836H3a1 1 0 01-1-1V3z"></path>
              </svg>
              {phone}
            </a>
          </li>
          <li>
            <a href="#ubicacion" class="flex items-center gap-2 text-slate-400 hover:text-blue-400 transition-colors duration-300 text-sm font-medium group">
              <svg class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
              </svg>
              {location}
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Redes Sociales -->
      <div>
        <h3 class="text-slate-100 font-bold text-sm uppercase tracking-wider mb-4">
          Síguenos
        </h3>
        <div class="flex flex-wrap gap-3">
          <!-- Facebook -->
          <a href="https://www.facebook.com/profile.php?id=61590611070282" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-10 h-10 bg-slate-800 hover:bg-blue-600 rounded-lg flex items-center justify-center text-slate-300 hover:text-white transition-all duration-300 group hover:scale-110 hover:shadow-lg hover:shadow-blue-600/50">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
            </svg>
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/acutewd/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 bg-slate-800 hover:bg-pink-600 rounded-lg flex items-center justify-center text-slate-300 hover:text-white transition-all duration-300 group hover:scale-110 hover:shadow-lg hover:shadow-pink-600/50">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"></path>
            </svg>
          </a>

          <!-- WhatsApp (Nuevo Logo Limpio y Redirección al Chat) -->
          <a href={`https://wa.me/${whatsappNumber}?text=Hola%20Acute!%20Me%20gustaría%20obtener%20más%20información%20sobre%20sus%20servicios.`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 bg-slate-800 hover:bg-green-600 rounded-lg flex items-center justify-center text-slate-300 hover:text-white transition-all duration-300 group hover:scale-110 hover:shadow-lg hover:shadow-green-600/50">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.4 0 12.008 0c3.202.001 6.212 1.246 8.477 3.513 2.263 2.268 3.507 5.28 3.503 8.487-.008 6.652-5.348 12-11.958 12-2.005-.001-3.973-.503-5.729-1.457L0 24zm6.59-4.046c1.654.982 3.511 1.5 5.409 1.5 5.315 0 9.642-4.327 9.648-9.647.003-2.577-1-5.002-2.82-6.825C17.06 3.16 14.636 2.16 12.01 2.16c-5.322 0-9.65 4.327-9.656 9.648-.001 2.02.527 3.991 1.53 5.733L2.895 21.19l3.752-1.236zM17.93 15.3c-.322-.16-1.905-.94-2.197-1.047-.294-.108-.507-.16-.72.16-.214.32-.828 1.047-1.014 1.26-.187.214-.373.24-.696.08-.322-.16-1.36-.5-2.59-1.6c-.957-.852-1.602-1.905-1.79-2.225-.186-.32-.02-.493.14-.654.146-.144.323-.374.484-.56.16-.188.214-.32.32-.534.108-.214.054-.4-.026-.56-.08-.16-.72-1.734-.987-2.374-.26-.625-.526-.54-.72-.55-.187-.01-.4-.01-.614-.01-.214 0-.56.08-.854.4-.294.32-1.12 1.1-1.12 2.678 0 1.578 1.147 3.1 1.307 3.32.16.214 2.257 3.447 5.467 4.837.763.33 1.357.527 1.82.674.766.244 1.463.21 2.013.127.614-.093 1.905-.78 2.172-1.496.267-.713.267-1.325.187-1.453-.08-.126-.294-.213-.615-.373z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-slate-800/50 mb-6"></div>

    <!-- Footer Bottom: Copyright & Legal -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-6">
      <p class="text-slate-500 text-sm text-center md:text-left">
        &copy; {currentYear} <span class="font-semibold text-slate-400">{companyName}</span>. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacidad" class="text-slate-500 hover:text-blue-400 text-sm transition-colors duration-300 font-medium">
          Política de Privacidad
        </a>
        <a href="/terminos" class="text-slate-500 hover:text-blue-400 text-sm transition-colors duration-300 font-medium">
          Términos de Servicio
        </a>
      </div>
    </div>
  </div>
</footer>