---
const projects = [
  {
    title: 'Plataforma de gestión logística',
    description: 'Sistema de control de rutas con dashboards en tiempo real y APIs escalables para transporte.',
    technologies: ['Node.js', 'Microservicios', 'Vue']
  },
  {
    title: 'CRM para ventas B2B',
    description: 'Solución flexible para equipos comerciales con automatización, informes y seguridad avanzada.',
    technologies: ['React', 'GraphQL', 'AWS']
  },
  {
    title: 'Portal de e-learning corporativo',
    description: 'Experiencia accesible y responsive para formación interna, con monitoreo de progreso y certificaciones.',
    technologies: ['Astro', 'Tailwind', 'Payment API']
  }
];
---

<section class="mt-16">
  <div class="flex items-baseline justify-between gap-6">
    <div>
      <p class="text-sm uppercase tracking-[0.3em] text-blue-500">Portafolio</p>
      <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Proyectos escalables con foco en resultados.</h2>
    </div>
  </div>
  
  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    {projects.map((project) => (
      <article class="rounded-3xl border border-slate-800/70 bg-slate-900/80 p-6 shadow-md hover:border-slate-700 transition-all duration-300 flex flex-col justify-between">
        <div>
          <h3 class="text-xl font-semibold text-white">{project.title}</h3>
          <p class="mt-3 text-slate-300 leading-7">{project.description}</p>
        </div>
        
        <!-- Contenedor de Tecnologías con espacio para Logos -->
        <div class="mt-6 flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <div class="inline-flex items-center gap-2 rounded-lg border border-slate-700/50 bg-slate-800/30 px-3 py-1.5 hover:bg-slate-800/60 hover:border-slate-600 transition-all duration-300">
              <!-- REEMPLAZAR EL SRC CON TUS LOGOS SVG/PNG POSTERIORMENTE -->
              <img 
                src="" 
                alt=""
                onerror="this.style.display='none'" 
                class="w-5 h-5 object-contain"
              />
              <span class="text-sm font-medium text-slate-300">{tech}</span>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>