---
// DATOS DE PROYECTOS
// imageUrl: ruta desde /public (ej. '/img/miLogo.jpg')
// projectUrl: URL externa; dejar '' para proyectos sin enlace publico
const projects = [
  {
    id: 'rant',
    title: 'Rant',
    category: 'Sistema de Restaurantes',
    description: 'Plataforma integral para la administracion, pedidos e inventario de restaurantes en tiempo real.',
    features: [
      'Gestion de mesas e inventarios automatizados.',
      'Panel analitico de ventas y rendimiento diario.',
      'Comandas digitales con sincronizacion instantanea.',
      'Menu interactivo con acceso rapido via codigo QR.',
    ],
    techStack: ['React', 'Node.js', 'PostgreSQL', 'Tailwind CSS'],
    imageUrl: '/img/rantLogo.jpg',
    projectUrl: 'https://rant.mx/',
  },
  {
    id: 'laavenida',
    title: 'La Avenida Seminuevos',
    category: 'Control Automotriz',
    description: 'Sistema a medida para el control de inventario, valuacion y venta de vehiculos seminuevos.',
    features: [
      'Catalogo digital interactivo con estatus en vivo.',
      'Control financiero de comisiones y utilidades.',
      'Generacion automatizada de contratos de compraventa.',
      'Historial de mantenimiento y peritajes tecnicos.',
    ],
    techStack: ['Next.js', 'Firebase', 'Tailwind CSS', 'Vercel'],
    imageUrl: '/img/laAvenidaLogo.jpg',
    projectUrl: 'http://laavenida.vercel.app/',
  },
  {
    id: 'remote',
    title: 'Remote',
    category: 'Automatizacion de Video',
    description: 'Automatizador en la nube para la creacion y renderizado rapido de contenido en video.',
    features: [
      'Generacion de escenas automaticas con inteligencia artificial.',
      'Renderizado distribuido ultra rapido via FFMPEG.',
      'Integracion nativa con voces sinteticas premium.',
      'Plantillas dinamicas para optimizar redes sociales.',
    ],
    techStack: ['React', 'Node.js', 'FFMPEG', 'AWS S3', 'OpenAI API'],
    imageUrl: '/img/remoteLogo.jpg',
    projectUrl: '',
  },
];
---

<section class="mt-16">

  <div class="mb-10">
    <p class="text-sm uppercase tracking-[0.3em] text-blue-500">Portafolio</p>
    <h2 class="mt-3 text-3xl font-semibold text-white sm:text-4xl">Casos de éxito destacados</h2>
    <p class="mt-2 text-slate-400 max-w-2xl text-sm sm:text-base leading-relaxed">
      Explora algunos de los sistemas a medida que hemos desarrollado para optimizar
      procesos comerciales y automatizar flujos de trabajo.
    </p>
  </div>

  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {projects.map((project) => {
      const isClickable = Boolean(project.projectUrl);
      return (
        <div class="flip-card w-full h-[460px] relative group">

          {isClickable ? (
            <a
              href={project.projectUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="absolute inset-0 z-30 rounded-3xl focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
              aria-label={"Visitar " + project.title}
            />
          ) : (
            <div class="absolute inset-0 z-30 rounded-3xl cursor-default" />
          )}

          <div class="flip-inner relative w-full h-full">

            {/* CARA FRONTAL */}
            <div class="flip-front absolute inset-0 rounded-3xl border border-slate-800/70 bg-slate-900/90 p-5 flex flex-col">
              <div class="absolute inset-x-0 top-0 h-px rounded-t-3xl bg-gradient-to-r from-transparent via-blue-500/50 to-transparent" />

              <div class="flex items-center justify-between gap-2 shrink-0">
                <span class="text-[10px] font-mono tracking-widest uppercase text-slate-400 bg-slate-950/70 px-3 py-1 rounded-full border border-slate-800/60">
                  {project.category}
                </span>
                {isClickable ? (
                  <span class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_6px_rgba(16,185,129,0.9)]" />
                    <span class="text-[10px] font-mono uppercase font-semibold tracking-wider text-emerald-400">Online</span>
                  </span>
                ) : (
                  <span class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400" />
                    <span class="text-[10px] font-mono uppercase font-semibold tracking-wider text-amber-400">Interno</span>
                  </span>
                )}
              </div>

              <div class="flex-1 flex items-center justify-center py-4">
                <img
                  src={project.imageUrl}
                  alt={"Logo de " + project.title}
                  class="max-h-52 w-auto object-contain drop-shadow-lg transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>

              <div class="shrink-0 flex items-center justify-center gap-1.5 text-[11px] font-medium text-slate-500">
                <span>Ver detalles del proyecto</span>
                <svg class="w-3 h-3 animate-bounce-x" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </div>
            </div>

            {/* CARA POSTERIOR */}
            <div class="flip-back absolute inset-0 rounded-3xl border border-slate-700/60 bg-slate-950 p-5 flex flex-col">
              <div class="absolute inset-x-0 top-0 h-px rounded-t-3xl bg-gradient-to-r from-transparent via-blue-500/50 to-transparent" />

              <h3 class="flex items-center gap-2 text-base font-bold text-white tracking-tight shrink-0">
                <span class="w-1 h-5 rounded-full bg-blue-500 shrink-0" />
                {project.title}
              </h3>

              <p class="mt-2 text-[12px] text-slate-400 leading-relaxed shrink-0">
                {project.description}
              </p>

              <ul class="mt-3 space-y-2 flex-1 overflow-hidden">
                {project.features.map((feat) => (
                  <li class="flex items-start gap-2 text-slate-300">
                    <span class="mt-0.5 shrink-0 w-4 h-4 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </span>
                    <span class="text-[12px] leading-snug">{feat}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-auto pt-3 border-t border-slate-800 flex flex-col gap-3 shrink-0">
                <div class="flex flex-wrap gap-1.5">
                  {project.techStack.map((tech) => (
                    <span class="px-2 py-0.5 rounded-md bg-slate-900 border border-slate-800 text-[10px] font-mono text-slate-400">
                      {tech}
                    </span>
                  ))}
                </div>

                {isClickable ? (
                  <div class="flex items-center justify-center gap-2 w-full rounded-xl bg-blue-600 py-2.5 text-sm font-semibold text-white shadow-lg shadow-blue-600/20 transition-colors duration-200 group-hover:bg-blue-500">
                    <span>Visitar sitio web</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </div>
                ) : (
                  <div class="flex items-center justify-center gap-2 w-full rounded-xl bg-slate-900 border border-slate-800 py-2.5 text-sm font-semibold text-slate-500">
                    <span>Proyecto Interno</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                  </div>
                )}
              </div>
            </div>

          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .flip-card {
    perspective: 1400px;
  }

  .flip-inner {
    transform-style: preserve-3d;
    transition: transform 0.75s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .flip-card:hover .flip-inner {
    transform: rotateY(180deg);
  }

  .flip-front {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .flip-back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform: rotateY(180deg);
  }

  @keyframes bounce-x {
    0%, 100% {
      transform: translateX(0);
      animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
    }
    50% {
      transform: translateX(4px);
      animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
    }
  }

  .animate-bounce-x {
    animation: bounce-x 1.2s ease-in-out infinite;
  }
</style>