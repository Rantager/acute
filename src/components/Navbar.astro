---
interface Props {
  companyName?: string;
}

const { companyName = 'Acute' } = Astro.props;
---

<nav class="sticky top-0 z-50 border-b border-slate-800/50 bg-slate-950/95 backdrop-blur-md transition-all duration-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
      <div class="flex items-center flex-shrink-0">
        <a href="/" class="flex items-center group">
          <img src="/img/logo.svg" alt="Acute Logo" class="w-auto h-12 object-contain group-hover:scale-105 transition-transform duration-300" />
        </a>
      </div>

      <div class="hidden md:flex items-center gap-8">
        <div class="flex items-center gap-6">
          <a href="/" class="text-slate-300 hover:text-blue-400 transition-colors duration-300 text-sm font-medium relative group py-1">
            Inicio
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 group-hover:w-full transition-all duration-300"></span>
          </a>

          <a href="/servicios" class="text-slate-300 hover:text-blue-400 transition-colors duration-300 text-sm font-medium relative group py-1">
            Servicios
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 group-hover:w-full transition-all duration-300"></span>
          </a>

          <a href="/proyectos" class="text-slate-300 hover:text-blue-400 transition-colors duration-300 text-sm font-medium relative group py-1">
            Proyectos
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 group-hover:w-full transition-all duration-300"></span>
          </a>

          <a href="/blog" class="text-slate-300 hover:text-blue-400 transition-colors duration-300 text-sm font-medium relative group py-1">
            Blog
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 group-hover:w-full transition-all duration-300"></span>
          </a>
        </div>

        <a href="/cotizar" class="px-6 py-2.5 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg font-medium text-sm hover:shadow-lg hover:shadow-blue-500/50 transform hover:scale-105 transition-all duration-300 whitespace-nowrap">
          Cotizar Proyecto
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-slate-300 hover:bg-slate-800 transition-colors duration-300" aria-label="Abrir menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-slate-800/50">
      <div class="space-y-1 pt-3">
        <a href="/" class="block px-4 py-2 text-slate-300 hover:text-blue-400 hover:bg-slate-800/50 rounded-lg transition-all duration-300 font-medium text-sm">Inicio</a>
        <a href="/servicios" class="block px-4 py-2 text-slate-300 hover:text-blue-400 hover:bg-slate-800/50 rounded-lg transition-all duration-300 font-medium text-sm">Servicios</a>
        <a href="/proyectos" class="block px-4 py-2 text-slate-300 hover:text-blue-400 hover:bg-slate-800/50 rounded-lg transition-all duration-300 font-medium text-sm">Proyectos</a>
        <a href="/blog" class="block px-4 py-2 text-slate-300 hover:text-blue-400 hover:bg-slate-800/50 rounded-lg transition-all duration-300 font-medium text-sm">Blog</a>
        
        <a href="/cotizar" class="block px-4 py-2.5 mt-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg font-medium text-sm hover:shadow-lg hover:shadow-blue-500/50 transition-all duration-300 text-center">
          Cotizar Proyecto
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  }
</script>