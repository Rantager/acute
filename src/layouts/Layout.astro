---
const { title, description, image } = Astro.props;
const siteUrl = 'https://www.acute.mx';

// 1. Dinamismo para la URL exacta y evitar contenido duplicado
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);

// 2. Mejoramos el título por defecto agregando tus palabras clave locales
const pageTitle = title ? `Acute | ${title}` : 'Acute | Desarrollo Web y Sistemas en Colima y Tecomán';

// 3. Mejoramos la descripción por defecto orientada a SEO local
const pageDescription = description ?? 'Agencia de software en Colima. Diseñamos y desarrollamos aplicaciones web, páginas interactivas y sistemas escalables en Colima y Tecomán.';

// 4. CORREGIDO: Agregamos /img/ para que coincida con tu estructura de archivos reales
const pageImage = image ?? `${siteUrl}/img/acute-logo.png`; 
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />

    <!-- Enlace Canónico esencial para SEO -->
    <link rel="canonical" href={canonicalUrl} />

    <title>{pageTitle}</title>

    <!-- CORREGIDO: Cambiado type a image/png y añadida la ruta /img/ para que Google encuentre tu logo -->
    <link rel="icon" type="image/png" href="/img/acute-logo.png" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />

    <!-- Open Graph / Redes Sociales (Cambiado a es_MX) -->
    <meta property="og:locale" content="es_MX" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Acute" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImage} />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased flex flex-col">
    <Navbar companyName="Acute" logoText="[Logo Empresa]" />
    
    <main class="flex-1">
      <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <slot />
      </div>
    </main>
    
    <Footer 
      companyName="Acute"
      companyDescription="Transformamos ideas en soluciones de software escalables y de alta calidad."
      email="acutewebdesign7@gmail.com"
      phone="+52 (313) 106 8471"
      location="Colima, México"
    />
  </body>
</html>