---
import Layout from '../layouts/Layout.astro';
import BlogInteractivo from '../components/BlogInteractivo.tsx';

// Escaneamos directamente tu carpeta existente en src/content/blog/
const archivosMarkdown = await Astro.glob('../content/blog/**/*.md');

// Mapeamos los datos asegurando que si falta un slug, tome el nombre del archivo
const ARTICULOS = archivosMarkdown.map(archivo => ({
  slug: archivo.frontmatter.slug || archivo.file.split('/').pop()?.replace('.md', '') || '',
  categoriaSlug: archivo.frontmatter.categoriaSlug,
  categoriaNombre: archivo.frontmatter.categoriaNombre,
  title: archivo.frontmatter.title,
  description: archivo.frontmatter.description,
  content: archivo.compiledContent() 
}));

type Articulo = typeof ARTICULOS[0];
type Categoria = { nombre: string; articulos: Articulo[] };

// Agrupamos dinámicamente por categoría
const temasAgrupados = ARTICULOS.reduce((acc: Record<string, Categoria>, articulo) => {
  if (!articulo.categoriaSlug) return acc; // Ignora archivos que no tengan categoría definida
  
  if (!acc[articulo.categoriaSlug]) {
    acc[articulo.categoriaSlug] = {
      nombre: articulo.categoriaNombre || articulo.categoriaSlug,
      articulos: []
    };
  }
  acc[articulo.categoriaSlug].articulos.push(articulo);
  return acc;
}, {});

// Convertimos a la estructura limpia que requiere la isla de React
const dataEstructurada = Object.entries(temasAgrupados).map(([slug, data]) => ({
  slug,
  nombre: data.nombre,
  articulos: data.articulos
}));
---

<Layout title="Centro de Recursos y Blog Técnico | Acute">
  <main class="min-h-screen bg-[#05070F] bg-gradient-to-b from-[#05070F] to-[#0B111E] text-white py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-[#2563EB]/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-0 w-96 h-96 bg-[#2563EB]/5 rounded-full blur-[120px] pointer-events-none"></div>

    <header class="mb-12 border-b border-[#2563EB]/10 pb-6">
      <h1 class="text-3xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400 sm:text-4xl">
        El Blog de Acute
      </h1>
      <p class="mt-3 text-sm text-[#94A3B8] max-w-2xl leading-relaxed">
        <!-- Pega aquí el subtítulo que más te convenza -->
        Tecnología a medida, arquitectura en la nube y estrategias de desarrollo explicadas desde su impacto financiero.
      </p>
    </header>

      {dataEstructurada.length > 0 ? (
        <BlogInteractivo client:load categorias={dataEstructurada} />
      ) : (
        <div class="text-center py-12 border border-[#2563EB]/10 rounded-xl bg-[#0B111E]">
          <p class="text-[#94A3B8] text-sm">No se detectaron artículos válidos en src/content/blog/</p>
        </div>
      )}
    </div>
  </main>
</Layout>