---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';

// Definimos las preguntas más comunes que conectan directo con los slugs de tus archivos Markdown
const PREGUNTAS_BLOG = [
  {
    pregunta: "¿Rentar software comercial o construir una solución a medida?",
    descripcion: "Análisis financiero del costo real: por qué las suscripciones SaaS terminan siendo una sangría interminable para tu negocio.",
    slug: "costo-real-software",
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  {
    pregunta: "¿Qué pasa si la agencia desaparece? ¿El código me pertenece?",
    descripcion: "El dilema del Vendor Lock-in. Por qué la documentación técnica y la propiedad absoluta del código fuente son indispensables.",
    slug: "vendor-lock-in",
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>`
  },
  {
    pregunta: "¿Desarrollar software a medida significa esperar meses o años?",
    descripcion: "El mito del desarrollo interminable. Cómo la arquitectura modular nos permite entregarte resultados y ROI desde el primer mes.",
    slug: "desarrollo-interminable",
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  {
    pregunta: "¿Cómo evitar el fraude interno y las alteraciones de precios?",
    descripcion: "La trazabilidad absoluta como auditor preventivo. Implementación de logs de auditoría inmutables para vigilar cada centavo de tu negocio.",
    slug: "trazabilidad-absoluta",
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`
  },
  {
    pregunta: "¿El software funcionará si mi internet en bodega es inestable?",
    descripcion: "Rendimiento en condiciones adversas. Diseñamos bajo arquitecturas minimalistas y de persistencia local para operar sin pérdida de datos.",
    slug: "rendimiento-redes-lentas",
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`
  },
  {
    pregunta: "¿Una venta en mostrador puede actualizar mi stock web al instante?",
    descripcion: "Sincronización omnicanal en tiempo real. Conecta tu tienda física, tu eCommerce y tu bodega a una base de datos centralizada y única.",
    slug: "sincronizacion-omnicanal",
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.253 8H18"></path></svg>`
  }

  
];
---

<Layout
  title="Desarrollo Web y Sistemas a la Medida en Colima y Tecomán | Acute"
  description="Agencia de software en Colima. Desarrollamos aplicaciones web, sistemas empresariales y apps móviles en Colima y Tecomán con alto rendimiento y entrega ágil."
  image="https://www.acute.mx/acute-logo.png" 
>
  <main class="space-y-24">
    <Hero />

    <!-- SECCIÓN: QUÉ CONSTRUIMOS -->
    <section class="scroll-mt-20">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-sm uppercase tracking-[0.3em] text-blue-500">Desarrollo Web</p>
        <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">¿Qué construimos en Acute?</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-3xl border border-slate-800/70 bg-slate-900/40 p-8 shadow-md hover:border-slate-700 hover:bg-slate-900/60 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-semibold text-white">Sistemas Web a Medida</h3>
          <p class="mt-3 text-slate-400 leading-relaxed text-sm">Aplicaciones empresariales, plataformas SaaS y paneles de administración robustos enfocados en optimizar tus operaciones.</p>
        </div>

        <div class="rounded-3xl border border-slate-800/70 bg-slate-900/40 p-8 shadow-md hover:border-slate-700 hover:bg-slate-900/60 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-semibold text-white">Aplicaciones Móviles</h3>
          <p class="mt-3 text-slate-400 leading-relaxed text-sm">Diseño y desarrollo de apps para iOS y Android fluidas, intuitivas y conectadas en tiempo real con tus servicios de backend.</p>
        </div>

        <div class="rounded-3xl border border-slate-800/70 bg-slate-900/40 p-8 shadow-md hover:border-slate-700 hover:bg-slate-900/60 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4m0 5c0 2.21-3.58 4-8 4s8-1.79 8-4"></path></svg>
          </div>
          <h3 class="text-xl font-semibold text-white">Backend & Datos</h3>
          <p class="mt-3 text-slate-400 leading-relaxed text-sm">Arquitectura de servidores estables, APIs REST/GraphQL rápidas y modelado de bases de datos óptimo y seguro.</p>
        </div>
      </div>
    </section>

    <!-- SECCIÓN: POR QUÉ ACUTE -->
    <section class="grid gap-12 lg:grid-cols-2 items-center bg-slate-950/40 rounded-[2rem] border border-slate-800/40 p-8 lg:p-12">
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-blue-500">¿Por qué Acute?</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Ingeniería de software enfocada en el rendimiento real.
        </h2>
        <p class="mt-4 text-slate-400 leading-relaxed">
          No solo escribimos líneas de código; diseñamos la estructura técnica desde nuestra base en Colima para que tu plataforma guante el crecimiento de usuarios sin perder velocidad ni estabilidad.
        </p>
      </div>

      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <div>
            <h4 class="text-base font-semibold text-white">Código modular y mantenible</h4>
            <p class="mt-1 text-sm text-slate-400">Separamos la lógica de negocio de las interfaces. Tu software podrá actualizarse fácilmente mañana sin romper lo que ya funciona hoy.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <div>
            <h4 class="text-base font-semibold text-white">Bases de datos normalizadas</h4>
            <p class="mt-1 text-sm text-slate-400">Estructuramos las tablas y relaciones de forma eficiente. Consultas rápidas, consistencia en la información y almacenamiento inteligente.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <div>
            <h4 class="text-base font-semibold text-white">Entregas incrementales por Sprint</h4>
            <p class="mt-1 text-sm text-slate-400">Trabajamos con metodologías ágiles. Verás avances reales del sistema de forma constante, asegurando que el producto final sea exactamente lo que necesitas.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- NUEVA SECCIÓN INTEGRADA: RESOLVIENDO DUDAS CORPORATIVAS -->
    <section class="scroll-mt-20 pb-12">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <p class="text-sm uppercase tracking-[0.3em] text-blue-500">Criterio Técnico</p>
        <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">Decisiones estratégicas de software</h2>
        <p class="mt-4 text-slate-400 text-sm">Antes de invertir en tecnología para tu empresa, resolvemos las dudas operativas y financieras más comunes del mercado.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {PREGUNTAS_BLOG.map((item) => (
          <a 
            href={`/blog?articulo=${item.slug}`} 
            class="group block p-6 rounded-2xl border border-slate-800/60 bg-slate-950/20 hover:border-blue-500/40 hover:bg-slate-900/40 transition-all duration-300 relative overflow-hidden"
          >
            <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-full blur-xl pointer-events-none group-hover:bg-blue-500/10 transition-colors"></div>
            
            <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 mb-4 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300" set:html={item.icono}>
            </div>

            <h3 class="text-base font-semibold text-white group-hover:text-blue-400 transition-colors duration-300 min-h-[3rem]">
              {item.pregunta}
            </h3>
            
            <p class="mt-2 text-xs text-slate-400 leading-relaxed">
              {item.descripcion}
            </p>

            <div class="mt-4 flex items-center text-xs font-semibold text-blue-400 gap-1 opacity-80 group-hover:opacity-100 group-hover:translate-x-1 transition-all">
              Leer respuesta completa 
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>